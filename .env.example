# ==========================================
# Identity (показывается в UI, брендирование)
# ==========================================
VITE_SAAS_NAME="My SaaS"
VITE_SUPPORT_EMAIL="support@example.com"
VITE_CURRENCY="USD"

# ==========================================
# Admin Supabase project
# (отдельный Supabase для super_admins, payments, audit_log)
# ==========================================
VITE_ADMIN_SUPABASE_URL=https://xxxxx.supabase.co
VITE_ADMIN_SUPABASE_ANON_KEY=eyJhbG...

# ==========================================
# Main SaaS Supabase project
# (только URL нужен клиенту, edge functions ходят с service_role)
# ==========================================
VITE_MAIN_SAAS_SUPABASE_URL=https://yyyyy.supabase.co

# ==========================================
# Billing
# ==========================================
VITE_BILLING_PROVIDER=paddle
VITE_PLANS_JSON='[{"id":"basic","name":"Basic","price":29},{"id":"pro","name":"Pro","price":79}]'
VITE_TRIAL_DAYS=14

# ==========================================
# Edge function secrets (ставятся через supabase secrets set, НЕ в репо)
# ==========================================
# MAIN_SAAS_SUPABASE_URL=...
# MAIN_SAAS_SERVICE_ROLE_KEY=...
# ADMIN_SUPABASE_URL=...
# ADMIN_SUPABASE_SERVICE_ROLE_KEY=...
